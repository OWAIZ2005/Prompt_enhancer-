# Required: Your OpenAI API Key
OPENAI_API_KEY=your_openai_api_key_here

# Optional: Port for the backend server to run on (Default is 3000)
PORT=3000

# Note: If you want to use Groq instead of OpenAI:
# 1. Provide your GROQ API Key here:
# GROQ_API_KEY=your_groq_api_key_here
# 2. In server.js, update the base URL and API token injection for Groq.
