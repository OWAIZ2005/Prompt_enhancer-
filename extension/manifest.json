{
  "manifest_version": 3,
  "name": "Universal Prompt Enhancer",
  "version": "2.0.0",
  "description": "Upgrade your AI prompts into expert queries on ChatGPT, Gemini, and Claude with a single click.",
  "permissions": [
    "storage",
    "activeTab"
  ],
  "host_permissions": [
    "https://chatgpt.com/*",
    "https://*.openai.com/*",
    "https://gemini.google.com/*",
    "https://claude.ai/*",
    "https://prompt-enhancer-vms9.onrender.com/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "css": [
        "content-widget.css"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_end"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Universal Prompt Enhancer"
  }
}
